#!/sbin/openrc-run
name="OpenPBS v23.06.06"
description="OpenPBS batch system"

mom_config=/var/spool/pbs/mom_priv/config
org_script=/opt/pbs/libexec/pbs_init.d
hostname=$(cat /etc/hostname)

prestart(){
  # cleanup stale lock files
  find /var/spool/pbs -name "*.lock" -delete
  rm -f /var/spool/pbs/datastore/postmaster.pid

  # Ensure correct permissions for spool directory
  mkdir -p /var/spool/pbs/spool /var/spool/pbs/undelivered
  chmod 1777 /var/spool/pbs/spool /var/spool/pbs/undelivered
  chown root:root /var/spool/pbs/spool /var/spool/pbs/undelivered
}

depend(){
  need net
}

start(){
  # get current runtime hostname
  actual_hostname=$(cat /etc/hostname)

  # rewrite PBS config files to start all server with current runtime hostname
  sed -i -e "s/PBS_SERVER=.*/PBS_SERVER=${actual_hostname}/" -e "s/PBS_START_MOM=0/PBS_START_MOM=1/" /etc/pbs.conf

  grep -q "PBS_AUTH_METHOD=MUNGE" /etc/pbs.conf || echo "PBS_AUTH_METHOD=MUNGE" >> /etc/pbs.conf
  grep -q 'PBS_SUPPORTED_AUTH_METHODS=munge' /etc/pbs.conf || echo 'PBS_SUPPORTED_AUTH_METHODS=munge' >> /etc/pbs.conf

  mkdir -p $(dirname ${mom_config}) 2>/dev/null
  echo "\$clienthost ${actual_hostname}" > ${mom_config}
  echo "\$restricted 127.0.0.1" >> ${mom_config}
  echo "\$restricted ${actual_hostname}" >> ${mom_config}
  echo "\$usecp *:/ /" >> ${mom_config}
  echo "\$min_check_poll 5" >> ${mom_config}
  echo "\$max_check_poll 10" >> ${mom_config}

  mkdir -p /run/postgresql 2>/dev/null
  chown postgres:postgres /run/postgresql

  # set port number of postgresql
  export PBS_DATA_SERVICE_PORT=5432

  ${org_script} start
}

stop(){
  ${org_script} stop
}

status(){
  ${org_script} status
}
